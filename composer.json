{
    "name": "sushilk/note-keeping",
    "description": "Note Keeping",
    "keywords": [
        "api",
        "crud",
        "note-keeping",
        "sushilk"
    ],
    "type": "project",
    "require": {
        "php": "^8.3",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/extension-installer": "^1.4",
        "phpunit/phpunit": "^13.1",
        "tomasvotruba/type-coverage": "^2.1",
        "laravel/pint": "^1.29"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Sushil Kumar",
            "email": "sushilkumbhar77@gmail.com"
        }
    ],
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "test:unit": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-text --coverage-clover coverage.xml",
        "test:lint": "vendor/bin/pint",
        "test:type": "vendor/bin/phpstan",
        "test": [
          "@test:lint",
          "@test:type",
          "@test:unit"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
